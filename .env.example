# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est ignoré par git.

# Backend API (Express : Plaid, IA, fiscalité)
VITE_API_URL=http://localhost:3001

# Supabase — projet (région UE pour RGPD)
# Récupérer dans Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dev seulement : saute l'écran de login en local (jamais en prod)
VITE_DEV_SKIP_AUTH=false

# ─── Backend (server.js) ───────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # clé Claude (catégorisation IA)
# CORS_ORIGINS=https://wealthtrack.app
# Auth backend : mêmes valeurs que VITE_SUPABASE_* (sans préfixe VITE_)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...  # vérif de plan (requirePlan). SECRET — jamais exposé au front

# ─── Stripe ────────────────────────────────────────────────────────
# Le code Stripe vit dans les Edge Functions Supabase. Ces secrets se
# posent via `supabase secrets set …`, PAS dans ce fichier server.
# STRIPE_SECRET_KEY=sk_live_...            # Dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET=whsec_...          # Dashboard → Webhooks → signing secret
# STRIPE_PRICE_ID=price_...                # Pro mensuel
# STRIPE_PRICE_PRO_ANNUAL=price_...        # Pro annuel
# STRIPE_PRICE_COUPLE_MONTHLY=price_...    # Couple mensuel
# STRIPE_PRICE_COUPLE_ANNUAL=price_...     # Couple annuel
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...  # Clé publique (préfixe VITE_ = exposée au front)
# APP_URL=https://wealthtrack.app          # URL de base pour les redirections Stripe
