# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est ignoré par git.

# Backend API (Express : Plaid, IA, fiscalité)
VITE_API_URL=http://localhost:3001

# Supabase — projet (région UE pour RGPD)
# Récupérer dans Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dev seulement : saute l'écran de login en local (jamais en prod)
VITE_DEV_SKIP_AUTH=false
